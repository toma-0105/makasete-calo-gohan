<% content_for :title, "マイページ - まかせてカロごはん" %>

<div class="min-h-screen flex flex-col">
  <main class="flex-1 px-5 py-6 max-w-sm mx-auto w-full">

    <h1 class="text-[20px] font-bold text-[#2a2810] mb-5">マイページ</h1>

    <%# プロフィールカード %>
    <div class="card bg-[#FFF8C4] border border-[#EAE070] rounded-xl">
      <div class="card-body p-5 gap-4">

        <%# 名前 %>
        <div>
          <p class="text-[11px] text-[#9a9570] font-medium mb-1">名前</p>
          <p class="text-[15px] text-[#3a3820] font-semibold"><%= @user.name %></p>
        </div>

        <div class="border-t border-[#E8E4B8]"></div>

        <%# メールアドレス %>
        <div>
          <p class="text-[11px] text-[#9a9570] font-medium mb-1">メールアドレス</p>
          <p class="text-[15px] text-[#3a3820] font-semibold"><%= @user.email %></p>
        </div>

      </div>
    </div>

    <div class="h-5"></div>

    <%# TDEE診断履歴カード %>
    <div class="card bg-[#FFF8C4] border border-[#EAE070] rounded-xl">
      <div class="card-body p-5 gap-2">
        <p class="text-[14px] font-bold text-[#2a2810]">TDEE診断履歴</p>
        <p class="text-[13px] text-[#7a7550]">まだTDEE診断を行っていません</p>
      </div>
    </div>

    <div class="h-5"></div>

    <%# 各種設定・履歴へのリンク %>
    <div class="flex flex-col gap-3">
      <%= link_to "アレルギー設定を変更", new_user_allergen_path,
            class: "block w-full border border-[#D8D4A8] text-[#5a5530] text-center py-3.5 rounded-lg text-[14px]" %>
      <%= link_to "献立履歴を見る", "#",
            class: "block w-full border border-[#D8D4A8] text-[#5a5530] text-center py-3.5 rounded-lg text-[14px]" %>
    </div>

  </main>
</div>
