<% content_for :title, "マイページ - まかせてカロごはん" %>

<div class="min-h-screen flex flex-col">
  <main class="flex-1 px-5 py-6 max-w-sm mx-auto w-full">

    <h1 class="text-[20px] font-bold text-[#2a2810] mb-5">マイページ</h1>

    <%# プロフィールカード %>
    <div class="card bg-[#FFF8C4] border border-[#EAE070] rounded-xl">
      <div class="card-body p-5 gap-4">

        <%# 名前 %>
        <div>
          <p class="text-[11px] text-[#9a9570] font-medium mb-1">名前</p>
          <p class="text-[15px] text-[#3a3820] font-semibold"><%= @user.name %></p>
        </div>

        <div class="border-t border-[#E8E4B8]"></div>

        <%# メールアドレス %>
        <div>
          <p class="text-[11px] text-[#9a9570] font-medium mb-1">メールアドレス</p>
          <p class="text-[15px] text-[#3a3820] font-semibold"><%= @user.email %></p>
        </div>

      </div>
    </div>

    <div class="h-5"></div>

    <%# TDEE診断履歴カード %>
    <div class="card bg-[#FFF8C4] border border-[#EAE070] rounded-xl">
      <div class="card-body p-5 gap-2">
        <p class="text-[14px] font-bold text-[#2a2810]">TDEE診断履歴</p>
        <% if @tdee_profile %>
          <p class="text-[13px] text-[#7a7550]">
            1日の消費カロリー目安：<span class="font-bold text-[#3a3820]"><%= number_with_delimiter(@tdee_profile.tdee.to_i) %> kcal</span>
          </p>
          <%# 体重・活動量の変化に合わせて診断し直せる導線 %>
          <%= link_to "TDEEを再診断する", new_tdee_profile_path,
                class: "block w-full border border-[#D8D4A8] bg-[#FFFEF5] text-[#5a5530] text-center py-2.5 rounded-lg text-[13px] mt-1" %>
        <% else %>
          <p class="text-[13px] text-[#7a7550]">まだTDEE診断を行っていません</p>
          <%# 未診断ユーザーが行き止まりにならないよう診断への導線を出す %>
          <%= link_to "TDEE診断を始める", new_tdee_profile_path,
                class: "block w-full bg-[#F9C639] text-[#2a2810] text-center py-3 rounded-lg text-[13px] font-medium mt-1" %>
        <% end %>
      </div>
    </div>

    <div class="h-5"></div>

    <%# 献立生成ボタン（TDEE診断済みのユーザーのみ表示） %>
    <% if @tdee_profile %>
      <div data-controller="loading">
        <%# ローディングオーバーレイ %>
        <div data-loading-target="overlay"
             class="hidden fixed inset-0 bg-[#FFFEF5]/90 flex flex-col items-center justify-center z-50">
          <div class="w-12 h-12 border-4 border-[#EAE070] border-t-[#F9C639] rounded-full animate-spin mb-4"></div>
          <p class="text-[15px] font-semibold text-[#3a3820]">献立を生成しています...</p>
          <p class="text-[12px] text-[#9a9570] mt-1">少しお待ちください</p>
        </div>

        <%= form_with url: menus_path, data: { action: "submit->loading#showLoading" } do |f| %>
          <%= f.submit "今日の献立を生成する",
                class: "block w-full bg-[#F9C639] text-[#3a3820] text-center py-3.5 rounded-lg text-[14px] font-semibold cursor-pointer" %>
        <% end %>
      </div>

      <div class="h-3"></div>
    <% end %>

    <%# 各種設定・履歴へのリンク %>
    <div class="flex flex-col gap-3">
      <%= link_to "アレルギー設定を変更", new_user_allergen_path,
            class: "block w-full border border-[#D8D4A8] text-[#5a5530] text-center py-3.5 rounded-lg text-[14px]" %>
      <%# 献立履歴は会員限定のため、ゲストには表示しない %>
      <% unless current_user.guest? %>
        <%= link_to "献立履歴を見る", menus_path,
              class: "block w-full border border-[#D8D4A8] text-[#5a5530] text-center py-3.5 rounded-lg text-[14px]" %>
      <% end %>
    </div>

  </main>
</div>
