<div class="flex-1 flex flex-col items-center justify-center px-4">
  <div class="w-full max-w-sm">

    <h2 class="text-2xl font-bold text-center mb-8">ログイン</h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <%= render "shared/error_messages", resource: resource %>

      <div class="mb-4">
        <%= f.label :email, "メールアドレス", class: "block text-sm mb-1" %>
        <%= f.email_field :email,
            placeholder: "example@mail.com",
            autofocus: true,
            autocomplete: "email",
            class: "input w-full bg-yellow-50 border-yellow-200" %>
      </div>

      <div class="mb-6">
        <%= f.label :password, "パスワード", class: "block text-sm mb-1" %>
        <%= f.password_field :password,
            placeholder: "パスワード",
            autocomplete: "current-password",
            class: "input w-full bg-yellow-50 border-yellow-200" %>
      </div>

      <div class="mb-3">
        <%= f.submit "ログイン",
            class: "btn w-full bg-yellow-400 hover:bg-yellow-500 border-none text-white font-bold" %>
      </div>

    <% end %>

    <%# アカウント登録せずに試せるゲストログイン %>
    <div class="mb-3">
      <%= button_to "ゲストでログイン", guest_login_path,
          class: "btn w-full bg-white border-yellow-300 text-yellow-700 hover:bg-yellow-50" %>
    </div>

    <div class="mb-3">
      <%= link_to "パスワードを忘れた方", new_user_password_path,
          class: "btn w-full bg-white border-yellow-400 text-yellow-500 hover:bg-yellow-50" %>
    </div>

    <div>
      <%= link_to "新規登録はこちら", new_user_registration_path,
          class: "btn w-full bg-white border-yellow-400 text-yellow-500 hover:bg-yellow-50" %>
    </div>
  </div>
</div>