<div class="min-h-screen flex flex-col items-center justify-center px-4">
  <div class="w-full max-w-sm">

    <h2 class="text-2xl font-bold text-center mb-8">アカウント作成</h2>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="mb-4">
        <%= f.label :name, "ユーザーネーム", class: "block text-sm mb-1" %>
        <%= f.text_field :name,
            placeholder: "例：taro_yamada",
            class: "input w-full bg-yellow-50 border-yellow-200" %>
      </div>

      <div class="mb-4">
        <%= f.label :email, "メールアドレス", class: "block text-sm mb-1" %>
        <%= f.email_field :email,
            placeholder: "example@mail.com",
            autocomplete: "email",
            class: "input w-full bg-yellow-50 border-yellow-200" %>
      </div>

      <div class="mb-4">
        <%= f.label :password, "パスワード", class: "block text-sm mb-1" %>
        <%= f.password_field :password,
            placeholder: "6文字以上",
            autocomplete: "new-password",
            class: "input w-full bg-yellow-50 border-yellow-200" %>
      </div>

      <div class="mb-6">
        <%= f.label :password_confirmation, "パスワード（確認）", class: "block text-sm mb-1" %>
        <%= f.password_field :password_confirmation,
            placeholder: "もう一度入力",
            autocomplete: "new-password",
            class: "input w-full bg-yellow-50 border-yellow-200" %>
      </div>

      <div class="mb-3">
        <%= f.submit "登録する",
            class: "btn w-full bg-yellow-400 hover:bg-yellow-500 border-none text-white font-bold" %>
      </div>

    <% end %>

    <div>
      <%= link_to "ログインはこちら", new_user_session_path,
          class: "btn w-full bg-white border-yellow-400 text-yellow-500 hover:bg-yellow-50" %>
    </div>

  </div>
</div>