<div class="container mx-auto p-4">
  <div class="flex justify-center">
    <div class="w-full max-w-md">
      <h1 class="text-3xl font-bold mb-6">アレルギーに該当するものを<br>選んでください</h1>
      
      <% if flash[:alert] %>
        <div class="alert alert-error mb-4">
          <span><%= flash[:alert] %></span>
        </div>
      <% end %>

      <%= form_with(model: @user_allergen, local: true) do |form| %>
        <div class="mb-6">
          <h2 class="text-lg font-semibold mb-3">特定原材料</h2>
          <div class="space-y-2">
            <% @allergen_masters.where(category: :mandatory).each do |allergen| %>
              <div class="form-control">
                <label class="label cursor-pointer justify-start gap-3">
                  <%= check_box_tag "allergen_ids[]", allergen.id, false, class: "checkbox" %>
                  <span class="label-text"><%= allergen.name %></span>
                </label>
              </div>
            <% end %>
          </div>
        </div>

        <div class="mb-6">
          <h2 class="text-lg font-semibold mb-3">特定原材料に準ずるもの</h2>
          <div class="space-y-2">
            <% @allergen_masters.where(category: :recommended).each do |allergen| %>
              <div class="form-control">
                <label class="label cursor-pointer justify-start gap-3">
                  <%= check_box_tag "allergen_ids[]", allergen.id, false, class: "checkbox" %>
                  <span class="label-text"><%= allergen.name %></span>
                </label>
              </div>
            <% end %>
          </div>
        </div>

        <div class="w-full">
          <%= form.submit "保存", class: "btn btn-primary w-full" %>
        </div>
      <% end %>
    </div>
  </div>
</div>