<div class="flex-1 flex flex-col items-center justify-center px-4 py-8">
  <div class="w-full max-w-sm">

    <h1 class="text-2xl font-bold text-center mb-2">TDEE診断</h1>
    <p class="text-sm text-center text-[#7a7550] mb-2">
      入力した情報をもとに<br>1日の消費カロリーを計算します
    </p>
    <%# 全角入力によるエラーを防ぐため、入力前に半角指定をアナウンスする %>
    <p class="text-xs text-center text-gray-500 mb-4">
      ※数字は半角で入力してください
    </p>

    <%# TDEEの用語説明。checkbox方式のcollapseでJS不要のタップ開閉にする %>
    <div class="collapse collapse-arrow bg-yellow-100 border border-yellow-300 rounded-xl mb-8">
      <input type="checkbox" />
      <div class="collapse-title text-sm font-bold text-[#3d6b35]">
        💡 TDEEとは？
      </div>
      <div class="collapse-content text-[13px] text-[#5a5530] leading-relaxed">
        <p>
          TDEE＝1日の総消費カロリー。<br>
          じっとしていても使う基礎代謝に、日々の活動分を上乗せした数値です。<br>
          このアプリではあなたのTDEEをもとに無理のない目標カロリーを設定し、献立を自動で生成します。
        </p>
      </div>
    </div>

    <%= form_with model: @tdee_profile, url: tdee_profiles_path do |f| %>
      <%= render "shared/error_messages", resource: @tdee_profile %>

      <div class="mb-4">
        <%= f.label :height, "身長 (cm)", class: "block text-sm mb-1" %>
        <%# step: 0.1 で小数点第一位までの入力を許可する %>
        <%= f.number_field :height,
            placeholder: "例：165.5",
            step: 0.1,
            class: "input w-full bg-yellow-50 border-yellow-200" %>
      </div>

      <div class="mb-4">
        <%= f.label :weight, "体重 (kg)", class: "block text-sm mb-1" %>
        <%# step: 0.1 で小数点第一位までの入力を許可する %>
        <%= f.number_field :weight,
            placeholder: "例：50.5",
            step: 0.1,
            class: "input w-full bg-yellow-50 border-yellow-200" %>
      </div>

      <div class="mb-4">
        <%= f.label :age, "年齢", class: "block text-sm mb-1" %>
        <%= f.number_field :age,
            placeholder: "例：20",
            class: "input w-full bg-yellow-50 border-yellow-200" %>
      </div>

      <div class="mb-4">
        <%= f.label :gender, "性別", class: "block text-sm mb-1" %>
        <div class="flex gap-4 mt-1">
          <label class="flex items-center gap-2">
            <%= f.radio_button :gender, :male %>
            <span class="text-sm">男性</span>
          </label>
          <label class="flex items-center gap-2">
            <%= f.radio_button :gender, :female %>
            <span class="text-sm">女性</span>
          </label>
        </div>
      </div>

      <div class="mb-8">
        <%= f.label :activity_level, "活動レベル", class: "block text-sm mb-1" %>
        <%# 先頭の案内文は disabled で選択不可にする %>
        <%# 案内文が選択されている間はグレー表示、選択可能な5つの選択肢は常に黒文字にする %>
        <%= f.select :activity_level,
            [
              ["例：週1〜2回の運動", "", { disabled: true, selected: true }],
              ["ほとんど運動しない", "sedentary"],
              ["週1〜3回運動する", "lightly_active"],
              ["週3〜5回運動する", "moderately_active"],
              ["週6〜7回運動する", "very_active"],
              ["非常に活発に動く", "super_active"]
            ],
            {},
            class: "select w-full bg-yellow-50 border-yellow-200 has-[option:disabled:checked]:text-gray-400 [&>option:not(:disabled)]:text-black" %>
      </div>

      <div>
        <%= f.submit "計算する",
            class: "btn w-full bg-yellow-400 hover:bg-yellow-500 border-none text-white font-bold" %>
      </div>

    <% end %>
  </div>
</div>