<div class="flex-1 flex flex-col items-center justify-center px-4 py-8">
  <div class="w-full max-w-sm">

    <h1 class="text-2xl font-bold text-center mb-2">あなたの1日の消費カロリー</h1>
    <p class="text-sm text-center text-[#7a7550] mb-8">
      これをもとに、あなたに合った食事を提案します
    </p>

    <%# TDEE結果 %>
    <div class="bg-yellow-50 border border-yellow-200 rounded-2xl p-8 text-center mb-4">
      <p class="text-6xl font-bold text-[#3d6b35] mb-2">
        <%= number_with_delimiter(@tdee_profile.tdee.to_i) %>
      </p>
      <p class="text-sm text-[#7a7550]">kcal / 日</p>
    </div>

    <%# 目標カロリーの予告説明 %>
    <div class="bg-white border border-[#EAE070] rounded-xl px-4 py-3 mb-6 text-[13px] text-[#5a5530] leading-relaxed">
      <p class="mb-1">
        あなたの消費カロリー（TDEE）は
        <span class="font-bold text-[#3d6b35]"><%= number_with_delimiter(@tdee_profile.tdee.to_i) %> kcal</span>
        です。
      </p>
      <p>
        無理なく体重を落としていくために、献立の目標カロリーは
        TDEEの85%にあたる
        <span class="font-bold text-[#3d6b35]"><%= number_with_delimiter(@tdee_profile.target_calories.to_i) %> kcal</span>
        で生成します。
      </p>
    </div>

    <%# ボタン %>
    <div class="flex flex-col gap-3">
      <%= button_to "献立を生成する", menus_path,
          class: "btn w-full bg-yellow-400 hover:bg-yellow-500 border-none text-white font-bold text-center" %>

      <%# マイページへ %>
      <%= link_to "マイページへ",
          mypage_path,
          class: "btn w-full bg-white hover:bg-gray-50 border border-gray-300 text-gray-700 font-bold text-center" %>
    </div>
  </div>
</div>