<% content_for :title, "まかせてカロゴハン - 献立を考えなくても、ダイエットは続く。" %>

<div class="min-h-screen flex flex-col">
  <%= render "shared/header" %>

  <main class="flex-1 flex flex-col gap-3.5 px-5 py-6 max-w-sm mx-auto w-full">

    <%# ヒーローセクション %>
    <div class="text-center">
      <div class="h-3"></div>
      <h1 class="text-[26px] font-bold text-[#2a2810] leading-[1.35]">
        献立を考えなくても、<br>ダイエットは続く。
      </h1>
      <div class="h-2.5"></div>
      <p class="text-[14px] text-[#7a7550] leading-[1.7]">
        TDEE診断で1日の消費カロリーを計算し、<br>あなたに合った朝・昼・夜の献立を提案します。
      </p>
      <div class="h-4"></div>
      <%= link_to "ゲストでログイン", "#",
            class: "block w-full bg-[#F9C639] text-[#3a3820] text-center py-3.5 rounded-lg text-[15px] font-semibold" %>
      <div class="h-2"></div>
      <%= link_to "ログイン", "#",
            class: "block w-full border border-[#D8D4A8] text-[#5a5530] text-center py-3.5 rounded-lg text-[15px]" %>
    </div>

    <div class="h-px bg-[#E8E4B8]"></div>

    <%# TDEE説明セクション %>
    <div>
      <p class="text-[18px] font-bold text-[#2a2810] text-center">TDEE診断とは？</p>
      <div class="h-2"></div>
      <p class="text-[13px] text-[#5a5530] leading-[1.5] text-center">
        1日に消費するカロリーを簡単に計算できます。
      </p>
      <div class="h-2.5"></div>
      <div class="bg-[#FFF8C4] border border-[#EAE070] rounded-[10px] p-4">
        <p class="text-[14px] font-semibold text-[#3a3820] mb-1.5 text-center">TDEE（総消費カロリー）とは</p>
        <p class="text-[13px] text-[#7a7550] leading-[1.6] text-center">
          身長・体重・年齢・活動量をもとに自動で計算します。<br>難しい知識は不要、入力するだけでOKです。
        </p>
      </div>
      <div class="h-2.5"></div>
      <%# 入力→算出 ビジュアル %>
      <div class="flex items-center gap-2.5">
        <div class="flex-1 bg-[#FFFEF5] border border-[#C8C4A0] rounded-lg p-3 text-center">
          <p class="text-[11px] text-[#9a9570] mb-1.5">入力するだけ</p>
          <p class="text-[13px] font-medium text-[#3a3820] leading-[1.4]">身長・体重<br>年齢・活動量</p>
        </div>
        <span class="text-[20px] text-[#C8C4A0]">→</span>
        <div class="flex-1 bg-[#E8F5E0] border border-[#A8D898] rounded-lg p-3 text-center">
          <p class="text-[11px] text-[#9a9570] mb-1.5">自動で算出</p>
          <p class="text-[22px] font-bold text-[#2a5010]">2,200</p>
          <p class="text-[11px] text-[#5a8040]">kcal / 日</p>
        </div>
      </div>
    </div>

    <div class="h-px bg-[#E8E4B8]"></div>

    <%# ステップセクション %>
    <div>
      <p class="text-[18px] font-bold text-[#2a2810] text-center">3ステップで始められます</p>
      <div class="h-3"></div>
      <div class="flex flex-col gap-3.5">
        <div class="flex items-start gap-3.5">
          <div class="w-[30px] h-[30px] rounded-full bg-[#3a3820] text-[#FDF9DD] text-[14px] font-bold flex items-center justify-center shrink-0">1</div>
          <div>
            <p class="text-[14px] font-semibold text-[#2a2810] mb-0.5">
              TDEE診断
              <span class="text-[10px] px-1.5 py-0.5 rounded-[10px] bg-[#FFF3A0] text-[#5a4a10] ml-1.5">約30秒</span>
            </p>
            <p class="text-[12px] text-[#7a7550] leading-[1.5]">身体情報を入力して消費カロリーを計算します。</p>
          </div>
        </div>
        <div class="flex items-start gap-3.5">
          <div class="w-[30px] h-[30px] rounded-full bg-[#3a3820] text-[#FDF9DD] text-[14px] font-bold flex items-center justify-center shrink-0">2</div>
          <div>
            <p class="text-[14px] font-semibold text-[#2a2810] mb-0.5">
              アレルギー設定
              <span class="text-[10px] px-1.5 py-0.5 rounded-[10px] bg-[#FFF3A0] text-[#5a4a10] ml-1.5">任意</span>
            </p>
            <p class="text-[12px] text-[#7a7550] leading-[1.5]">食物アレルギー選択。（スキップも可能）</p>
          </div>
        </div>
        <div class="flex items-start gap-3.5">
          <div class="w-[30px] h-[30px] rounded-full bg-[#3a3820] text-[#FDF9DD] text-[14px] font-bold flex items-center justify-center shrink-0">3</div>
          <div>
            <p class="text-[14px] font-semibold text-[#2a2810] mb-0.5">献立を生成</p>
            <p class="text-[12px] text-[#7a7550] leading-[1.5]">朝・昼・夜の3食分が即座に表示されます。</p>
          </div>
        </div>
        <div class="flex items-start gap-3.5">
          <div class="w-[30px] h-[30px] rounded-full bg-[#3a3820] text-[#FDF9DD] text-[14px] font-bold flex items-center justify-center shrink-0">4</div>
          <div>
            <p class="text-[14px] font-semibold text-[#2a2810] mb-0.5">
              アカウント登録
              <span class="text-[10px] px-1.5 py-0.5 rounded-[10px] bg-[#FFF3A0] text-[#5a4a10] ml-1.5">任意</span>
            </p>
            <p class="text-[12px] text-[#7a7550] leading-[1.5]">保存・履歴確認が可能になります。</p>
          </div>
        </div>
      </div>
    </div>

  </main>

  <%# 下部CTA %>
  <div class="bg-[#FFF8C4] border-t border-[#EEE9C0] px-5 py-5">
    <div class="max-w-sm mx-auto">
      <%= link_to "さっそくはじめる", "#",
            class: "block w-full bg-[#F9C639] text-[#3a3820] text-center py-3.5 rounded-lg text-[15px] font-semibold" %>
    </div>
  </div>

  <%= render "shared/footer" %>
</div>
